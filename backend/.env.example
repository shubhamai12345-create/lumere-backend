# ─── Database (Railway PostgreSQL) ───────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/lumere

# ─── Razorpay ─────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Shiprocket ───────────────────────────────────────
# Use the email + password you registered at shiprocket.in
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=yourpassword

# ─── Odoo (free one-user plan on odoo.com) ────────────
# 1. Sign up at odoo.com → choose Invoicing as your one free app
# 2. Settings → Technical → API Keys → Create key
ODOO_URL=https://yourcompany.odoo.com
ODOO_DB=yourcompany
ODOO_USERNAME=your@email.com
ODOO_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
